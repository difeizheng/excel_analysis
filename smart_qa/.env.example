# LLM (OpenAI 兼容) 必填项 — 复制为 .env 填值
# 这套配置统一用于:意图解析(查询时,可选)+ schema_proposer(离线 schema 生成)
# 任何 OpenAI 兼容服务都可用: OpenAI / 智谱 / 通义 / DeepSeek / 月之暗面 / 本地 Ollama(v1+)

# 示例: 智谱 GLM-4
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# 示例: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 示例: 本地 Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# 测试:不配 key 时回退到规则解析器
LLM_FALLBACK_TO_RULES=true
